     </property>
     <property name="title">
      <string>控制器命名规则</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QLineEdit" name="ctl_name_rule_lineEdit">
          <property name="toolTip">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;自定义命名规则：&lt;/span&gt;&lt;/p&gt;&lt;p&gt;要配置自定义名称，请使用以下标记与 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;{}&lt;/span&gt;&amp;quot;&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;{component}&lt;/span&gt; = 组件名称&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;{side}&lt;/span&gt; = 组件的侧&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;{index&lt;/span&gt;} = 组件的索引。当有多个同名组件时这很重要&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;{description}&lt;/span&gt; = 组件内对象的名称&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;{extension}&lt;/span&gt; = 对象的扩展名。例如控制器用 &amp;quot;ctl&amp;quot;，关节用 &amp;quot;jnt&amp;quot;&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;NOTE:&lt;/span&gt; the only valid separator is &amp;quot;_&amp;quot;. This is a Maya limitation.&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;This is the default configuration:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;{component}_{side}{index}_{description}_{extension}&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Other examples of configurations:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;{component}{side}{index}{description}{extension}&lt;/p&gt;&lt;p&gt;{component}{index}_{description}_{extension}_{side}&lt;/p&gt;&lt;p&gt;{component}{index}_some_random_text_{description}_{extension}_{side}&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;It is recommended to use all the tokens to ensure that there is no name clashing&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="text">
           <string>{component}_{side}{index}_{description}_{extension}</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="reset_ctl_name_rule_pushButton">
          <property name="maximumSize">
           <size>
            <width>40</width>
            <height>16777215</height>
           </size>
          </property>
          <property name="text">
           <string>重置</string>
          </property>
         </widget>
        </item>
       </layout>
