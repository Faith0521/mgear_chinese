  <property name="windowTitle">
   <string>表单</string>
  </property>
  <layout class="QGridLayout" name="gridLayout_2">
   <item row="4" column="0">
    <widget class="QGroupBox" name="groupBox_3">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Preferred" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="title">
      <string>关节设置</string>
     </property>
     <layout class="QGridLayout" name="gridLayout_5">
      <item row="1" column="0">
       <widget class="QCheckBox" name="jointWorldOri_checkBox">
        <property name="enabled">
         <bool>true</bool>
        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;强制所有关节在世界空间中定向&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>强制世界方向</string>
        </property>
       </widget>
      </item>
      <item row="3" column="0">
       <widget class="QCheckBox" name="connect_joints_checkBox">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;启用此选项后，mGear Shifter 将尝试连接到场景中现有的关节&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;警告&lt;/span&gt;：关节的旋转值需要冻结为 0, 0, 0。&lt;/p&gt;&lt;p&gt;使用 Maya 的 修改 &amp;gt;&amp;gt; 冻结变换 命令来冻结旋转。打开命令选项并确保仅冻结旋转，然后再执行命令&lt;/p&gt;&lt;p&gt;冻结关节旋转步骤：&lt;/p&gt;&lt;p&gt;1. 选择要冻结的所有关节&lt;/p&gt;&lt;p&gt;2. 打开 Maya 的 修改 &amp;gt;&amp;gt; 冻结变换 选项并确保仅勾选旋转&lt;/p&gt;&lt;p&gt;3. 应用 修改 &amp;gt;&amp;gt; 冻结变换&lt;/p&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>连接到现有关节</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QCheckBox" name="force_uniScale_checkBox">
        <property name="text">
         <string>通过将所有轴连接到Z轴来强制所有关节统一缩放</string>
        </property>
       </widget>
      </item>
      <item row="0" column="0">
       <widget class="QCheckBox" name="jointRig_checkBox">
        <property name="text">
         <string>分离的关节结构</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item row="1" column="0">
    <widget class="QGroupBox" name="groupBox_6">
     <property name="title">
      <string>动画通道设置</string>
     </property>
     <layout class="QGridLayout" name="gridLayout_8">
      <item row="0" column="0">
       <widget class="QCheckBox" name="proxyChannels_checkBox">
        <property name="text">
         <string>添加内部代理通道</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QCheckBox" name="classicChannelNames_checkBox">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;如果勾选此选项，通道名将使用唯一的完整名称。&lt;/p&gt;&lt;p align=&quot;center&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;例如: &amp;quot;arm_L0_blend&amp;quot;&lt;/span&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;如果取消勾选，通道将使用简单名称。&lt;/p&gt;&lt;p align=&quot;center&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;例如: &amp;quot;arm_blend&amp;quot;&lt;/span&gt;&lt;br/&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;注意&lt;/span&gt;：取消勾选选项时。如果通道宿主(uiHost)有2个或更多相同类型的组件，连接将在所有具有相同名称通道的组件之间共享。 &lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;i.e:&lt;/span&gt; If we have 2 arms, the channels will be shared for both arms. To avoid this behaviour with the unchecked option, please use a unique channel host for each component.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>使用经典通道名（所有通道将拥有唯一名称）</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QCheckBox" name="attrPrefix_checkBox">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;如果勾选此选项，属性前缀将使用&lt;span style=&quot; font-style:italic; text-decoration: underline;&quot;&gt;组件实例名称&lt;/span&gt;而非&lt;span style=&quot; font-style:italic; text-decoration: underline;&quot;&gt;组件类型名称&lt;/span&gt;。&lt;/p&gt;&lt;p&gt;例如，如果使用 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;arm_2jnt_01&lt;/span&gt;&amp;quot; 组件且取消勾选经典通道名选项，IK/FK 混合的名称将为 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;arm_blend&lt;/span&gt;&amp;quot; &lt;/p&gt;&lt;p&gt;This will match the default name of the &lt;span style=&quot; font-style:italic; text-decoration: underline;&quot;&gt;component type&lt;/span&gt; &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;arm&lt;/span&gt;&amp;quot; but if we change the name of the &lt;span style=&quot; font-style:italic; text-decoration: underline;&quot;&gt;component instance&lt;/span&gt; for other: for example &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;limb&lt;/span&gt;&amp;quot; the attribute name will not change.&lt;/p&gt;&lt;p&gt;With this option checked the attribute name will match the &lt;span style=&quot; font-style:italic; text-decoration: underline;&quot;&gt;component instance name&lt;/span&gt; &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;limb&lt;/span&gt;&amp;quot; so the name of the attribute will be &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;limb_blend&lt;/span&gt;&amp;quot; and not the component type name.&lt;/p&gt;&lt;p&gt;this will also affect the way that the attributes are shared when we have a shared UI host.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>使用组件实例名作为属性前缀</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
