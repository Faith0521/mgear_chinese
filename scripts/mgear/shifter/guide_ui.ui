     <property name="title">
      <string>基础绑定控制</string>
     </property>
     <layout class="QHBoxLayout" name="horizontalLayout_9">
      <item>
       <widget class="QCheckBox" name="worldCtl_checkBox">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Shifter 默认创建一个名为 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;global_C0_ctl&lt;/span&gt;&amp;quot; 的基础控制器。&lt;/p&gt;&lt;p&gt;由于此控制器无法从任何引导定位器访问，无法将其添加为空间参考。&lt;/p&gt;&lt;p&gt;如果启用此选项，基础控制器将命名为 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;world_ctl&lt;/span&gt;&amp;quot;，我们可以将 &amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;global_C0_ctl&lt;/span&gt;&amp;quot; 添加为常规的 &amp;quot;Control_01&amp;quot; 组件。&lt;/p&gt;&lt;p&gt;这样我们就可以将其用作空间参考。&lt;/p&gt;&lt;p&gt;双足引导模板已配置此结构。&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>使用世界控制器或自定义名称</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="worldCtl_lineEdit">
        <property name="text">
         <string>world_ctl</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
