        </item>
        <item>
         <widget class="QCheckBox" name="addLeafJoint_checkBox">
          <property name="enabled">
           <bool>false</bool>
          </property>
          <property name="toolTip">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;当勾选&amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;添加叶关节&lt;/span&gt;&amp;quot;时，组件将添加一个额外的关节作为叶关节。因此将会有 2 个关节：一个用于连接关节结构，另一个用于驱动蒙皮并允许在游戏引擎工作流中进行非均匀缩放&lt;/p&gt;&lt;p&gt;这与将控制器标记为&amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;是叶关节&lt;/span&gt;&amp;quot;不同。&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="text">
           <string>添加叶关节</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="leafJoint_checkBox">
          <property name="enabled">
           <bool>false</bool>
          </property>
          <property name="toolTip">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;当勾选&amp;quot;&lt;span style=&quot; font-weight:600;&quot;&gt;是叶关节&lt;/span&gt;&amp;quot;时，组件将只创建关节而不创建控制器&lt;/p&gt;&lt;p&gt;顾名思义，此选项用于创建叶关节，但也可以用于创建&amp;quot;分支&amp;quot;&lt;/p&gt;&lt;p&gt;叶关节可用作变形辅助和/或游戏管线&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
          <property name="text">
           <string>是叶关节</string>
          </property>
         </widget>
        </item>
